    <script>
        // Печатная машинка
        const text = "Инженер технической поддержки L3";
        let i = 0;
        function type() {
            if (i < text.length) {
                document.getElementById('typewriter').textContent += text.charAt(i);
                i++;
                setTimeout(type, 100);
            }
        }

        // Анимация при скролле
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    const progress = entry.target.querySelectorAll('.skill-progress');
                    progress.forEach(p => {
                        setTimeout(() => { p.style.width = p.dataset.width; }, 200);
                    });
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.job, #skills, #achievements, #about').forEach(el => observer.observe(el));

        window.onload = type;

        // Динамический фон
        const canvas = document.getElementById('bg');
        const ctx = canvas.getContext('2d');
        let particles = [];
        const particleCount = 68;

        class Particle {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.vx = (Math.random() - 0.5) * 0.55;
                this.vy = (Math.random() - 0.5) * 0.55;
                this.radius = Math.random() * 1.6 + 0.9;
            }
            update() {
                this.x += this.vx;
                this.y += this.vy;
                if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
                if (this.y < 0 || this.y > canvas.height) this.vy *= -1;
            }
            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(0, 255, 65, 0.75)';
                ctx.fill();
            }
        }

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }

        function connectParticles() {
            for (let i = 0; i < particles.length; i++) {
                for (let j = i + 1; j < particles.length; j++) {
                    const dx = particles[i].x - particles[j].x;
                    const dy = particles[i].y - particles[j].y;
                    const distance = Math.sqrt(dx * dx + dy * dy);
                    if (distance < 135) {
                        ctx.beginPath();
                        ctx.strokeStyle = `rgba(0, 255, 65, ${0.18 * (1 - distance / 135)})`;
                        ctx.lineWidth = 0.65;
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        ctx.stroke();
                    }
                }
            }
        }

        function animateBackground() {
            ctx.fillStyle = 'rgba(5, 5, 5, 0.065)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => {
                p.update();
                p.draw();
            });
            connectParticles();
            requestAnimationFrame(animateBackground);
        }

        function initBackground() {
            resizeCanvas();
            particles = [];
            for (let i = 0; i < particleCount; i++) {
                particles.push(new Particle());
            }
            animateBackground();
        }

        window.addEventListener('resize', resizeCanvas);
        initBackground();
    </script>
