    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            /* Возвращаем черно-зеленую палитру */
            --bg-color: #050505;
            --text-color: #a9b7c6;
            --accent-color: #00ff41;
            --border-color: rgba(34, 34, 34, 0.6);
            --card-bg: rgba(10, 10, 10, 0.75);
            --glow: 0 0 15px rgba(0, 255, 65, 0.2);
        }
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            scroll-behavior: smooth;
        }
        body {
            font-family: 'Fira Code', monospace;
            color: var(--text-color);
            line-height: 1.6;
            padding: 0 20px;
            overflow-x: hidden;
            background-color: var(--bg-color);
            background: radial-gradient(circle at 50% 0%, #0a1f0f 0%, #050505 50%);
        }
        #bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            pointer-events: none;
        }
        .container {
            max-width: 950px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }
        .glass-panel {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
        }
        header {
            padding: 100px 0 60px 0;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        h1 {
            font-size: clamp(2.5rem, 8vw, 4rem);
            color: #fff;
            margin-bottom: 10px;
            letter-spacing: -1px;
        }
        .hero-details {
            margin: 20px 0;
            color: #888;
            font-size: 0.95rem;
        }
        .hero-details span {
            border-right: 1px solid #444;
            padding: 0 10px;
        }
        .hero-details span:first-child {
            padding-left: 0;
        }
        .hero-details span:last-child {
            border-right: none;
        }
        .typewriter-text {
            color: var(--accent-color);
            font-size: 1.5rem;
            min-height: 1.6em;
        }
        .cursor {
            display: inline-block;
            width: 10px;
            height: 1.2em;
            background: var(--accent-color);
            animation: blink 1s step-end infinite;
            vertical-align: middle;
        }
        @keyframes blink {
            50% {
                opacity: 0;
            }
        }
        h2 {
            font-size: 2rem;
            color: #fff;
            margin: 60px 0 30px;
            border-left: 4px solid var(--accent-color);
            padding-left: 20px;
        }
        .about-section {
            padding: 30px;
            font-size: 1.05rem;
        }
        .about-section p {
            margin-bottom: 15px;
        }
        .about-section p:last-child {
            margin-bottom: 0;
        }
        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .skill-item {
            padding: 20px;
            transition: transform 0.3s ease;
        }
        .skill-item:hover {
            transform: translateY(-3px);
            border-color: rgba(0, 255, 65, 0.4);
            box-shadow: var(--glow);
        }
        .skill-bar {
            height: 3px;
            background: #222;
            margin-top: 15px;
            position: relative;
            overflow: hidden;
            border-radius: 2px;
        }
        .skill-progress {
            height: 100%;
            background: var(--accent-color);
            width: 0;
            transition: width 1.5s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .tags {
